<?xml version="1.0"?>
<root BTCPP_format="4" main_tree_to_execute="AutonomousLoaderTree">

    <BehaviorTree ID="SafeNavigate">
        <Sequence>
            <RetryUntilSuccessful num_attempts="-1">
                <Sequence>
                    <!-- Step 1: Reset states and send the navigation goal -->
                    <Sequence>
                        <ResetNavigationArrived/>
                        <ResetDistanceToGoal/>
                        <ResetDistanceReduction/>
                        <ResetPlanningFeedback/>
                        <SendNavigationGoal goal="{goal}" status="{status}"/>
                    </Sequence>

                    <!-- Step 2: Wait for immediate planning feedback. If it fails, request intervention. -->
                    <Fallback>
                        <!-- Attempt to wait for successful planning feedback -->
                        <Sequence>
                            <WaitForPlanningFeedback timeout="20.5"/>
                            <!-- If planning is successful, then wait for the final navigation result -->
                            <WaitForNavigationResult
                                success="{success}"
                                final_distance_error="{dist_error}"
                                final_angle_error="{angle_error}"
                                error_code="{error_code}"
                                error_msg="{error_msg}"/>
                        </Sequence>
                        <!-- If WaitForPlanningFeedback fails (due to planning failure or timeout) -->
                        <Sequence>
                            <RequestManualIntervention message="Path planning failed or timed out."/>
                            <WaitForManualIntervention/>
                            <Sleep msec="1000"/>
                            <AlwaysFailure/>
                        </Sequence>
                    </Fallback>

                    <!-- Step 3: Check the final result from the navigation action -->
                    <Fallback>
                        <BlackboardCheck key="success" expected="true"/>
                        <!-- If goal was not reached, check if the error is recoverable -->
                        <Fallback>
                            <Sequence>
                                <CheckErrorCode error_code="{error_code}" recoverable_codes="102"/>
                                <AlwaysFailure/>
                            </Sequence>
                            <Sequence>
                                <RequestManualIntervention message="{error_msg}"/>
                                <WaitForManualIntervention/>
                                <AlwaysFailure/>
                            </Sequence>
                        </Fallback>
                    </Fallback>

                    <!-- Step 4: Check for Arrival Quality Failure (only for dumping) -->
                    <Fallback>
                        <Inverter>
                            <CheckNavStatus status="{status}" expected="1"/>
                        </Inverter>
                        <Fallback>
                            <CheckArrivalQuality distance_error="{dist_error}" angle_error="{angle_error}"/>
                            <Sequence>
                                <RequestManualIntervention message="Dumping arrival quality is poor. Please intervene."/>
                                <WaitForManualIntervention/>
                                <AlwaysFailure/>
                            </Sequence>
                        </Fallback>
                    </Fallback>
                </Sequence>
            </RetryUntilSuccessful>
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="AutonomousLoaderTree">
        <!-- Root: Reactive Fallback to prioritize Stop/Pause commands -->
        <ReactiveFallback name="ROOT">

            <!-- 1) Stop Sequence -->
            <Sequence name="SEQ_STOP">
                <CheckEndTask name="CheckEndTask"/>
                <SetGoalToParking goal="{parking_goal}"/>
                <SubTree ID="SafeNavigate" goal="{parking_goal}" status="2"/>
                
                <!-- Step 10: Reset arm and bucket at the end of the mission -->
                <SetArmBucketState name="SetABS_1_End" code="1"/>
                <WaitForArmBucketCompletion name="WaitABS_1_End" timeout_s="0" message="Mission ended, resetting arm and bucket"/>

                <UpdateTaskProgress name="StopProgress" phase="stopping" progress="100.0" message="Mission ended, returned to park and reset."/>
            </Sequence>

            <!-- 2) Pause Sequence -->
            <Sequence name="SEQ_PAUSE">
                <CheckPauseTask name="CheckPauseTask"/>
                <PauseNavigation name="PauseNavigation"/>
                <UpdateTaskProgress name="PauseProgress" phase="paused" progress="0.0" message="Task paused"/>
            </Sequence>

            <!-- 3) Main Work/Idle Fallback -->
            <Fallback name="SEL_WORK_IDLE">

                <!-- 3.1 Task Loop Entry -->
                <Sequence name="SEQ_TASK_LOOP">
                    <CheckNewTask name="CheckNewTask"/>
                    <GetAndSetCurrentTask name="GetAndSetCurrentTask"/>

                    <!-- On new task: prepare arm if first task, or if last command (1) completed -->
                    <Fallback name="FALLBACK_PREPARE_ARM_FIRST_TASK">
                        <!-- Case 1: first task after node start -->
                        <Sequence name="SEQ_PREPARE_ARM_IF_FIRST">
                            <IsFirstTask name="IsFirstTask"/>
                            <SetArmBucketState name="SetABS_2_Init" code="2"/>
                            <WaitForArmBucketCompletion name="WaitABS_2_Init" timeout_s="0" message="Task started, preparing arm"/>
                        </Sequence>
                        <!-- Case 2: previous cycle ended with ABS=1 (and completed to 10) -->
                        <Sequence name="SEQ_PREPARE_ARM_IF_RESET_DONE">
                            <CheckArmBucketDone name="WasABS1Completed" expect_code="1"/>
                            <SetArmBucketState name="SetABS_2_Reinit" code="2"/>
                            <WaitForArmBucketCompletion name="WaitABS_2_Reinit" timeout_s="0" message="Arm was reset (1), preparing arm"/>
                        </Sequence>
                        <!-- Default: do nothing and continue -->
                        <AlwaysSuccess/>
                    </Fallback>

                    <!-- Multi-cycle loop -->
                    <KeepRunningUntilFailure name="RepeatUntilFail">
                        <Sequence name="SEQ_ONE_CYCLE">

                            <!-- A: Select and navigate to the final scoop point -->
                            <Sequence name="SEQ_SCOOP_POINT_NAV">
                                <UpdateTaskProgress name="UP_SCP_REQ" phase="scooping" progress="20.0" message="Requesting scoop point"/>
                                <RequestScoopPoint name="RequestScoopPoint"/>

                                <Fallback name="SEL_HANDLE_SCOOP_POINT">
                                    <!-- (0,0) case: Navigate to bin center -> Accumulate points -> Re-request scoop point -->
                                    <Sequence name="SEQ_ZERO_CASE">
                                        <CheckScoopPointZero name="CheckScoopPointZero"/>
                                        <SetGoalToBinCenter goal="{bin_center_goal}"/>
                                        <SubTree ID="SafeNavigate" goal="{bin_center_goal}" status="0"/>
                                        <SetPointAccumulationStart name="StartAccumulation"/>
                                        <WaitForPointAccumulationDone name="WaitAccumulation" timeout_s="0" message="Arrived at bin center, waiting for point cloud calculation"/>
                                        <RequestScoopPoint name="RequestScoopPoint_Again"/>
                                    </Sequence>
                                    <!-- Non-(0,0) case: Proceed directly -->
                                    <Inverter><CheckScoopPointZero/></Inverter>
                                </Fallback>

                                <!-- Always set the scoop point goal before the parallel navigation and scooping actions -->
                                <SetGoalToScoopPoint goal="{scoop_point_goal}"/>
                            </Sequence>

                            <!-- B & C: Parallel Navigation and Scooping Actions -->
                           <Parallel name="PARALLEL_NAV_AND_SCOOP_ACTIONS" success_count="2" failure_count="1">

                                <SubTree ID="SafeNavigate" goal="{scoop_point_goal}" status="0"/>

                                <Sequence name="SEQ_SCOOP_ACTIONS_ON_APPROACH">
                                    <WaitForPlanningFeedback timeout="20.5"/>

                                    <Fallback name="FALLBACK_LOWER_ARM_LEAVING_HOPPER">
                                        <Sequence name="SEQ_LOWER_ARM_TRANSIT">
                                            <CheckDistanceFromLastHopper distance_gt="7.0"/>
                                            
                                            <Inverter>
                                                <CheckArmBucketDone expect_code="3"/> </Inverter>
                                            
                                            <SetArmBucketState code="5"/>
                                            <WaitForArmBucketCompletion message="Leaving hopper (>7m), lowering arm"/>
                                        </Sequence>
                                        <AlwaysSuccess/> </Fallback>

                                    <RetryUntilSuccessful num_attempts="-1">
                                        <Fallback>
                                            <CheckArmBucketDone expect_code="3"/>
                                            <Sequence>
                                                <CheckDistanceThreshold threshold_name="lower_bucket_distance"/>
                                                <SetArmBucketState code="3"/>
                                                <WaitForArmBucketCompletion message="Approaching scoop point (<=3m), lowering bucket"/>
                                            </Sequence>
                                        </Fallback>
                                    </RetryUntilSuccessful>

                                    <RetryUntilSuccessful num_attempts="-1">
                                        <Fallback>
                                            <CheckArmBucketDone expect_code="7"/>
                                            <Sequence>
                                                <WaitForNavigationArrival message="Waiting nav arrival to scoop"/>
                                                <SetArmBucketState code="7"/>
                                                <WaitForArmBucketCompletion message="Arrived at scoop point, starting scoop"/>
                                            </Sequence>
                                        </Fallback>
                                    </RetryUntilSuccessful>
                                    <AlwaysSuccess/>
                                </Sequence>

                            </Parallel>

                            <!-- D: Dumping Phase -->
                            <Sequence name="SEQ_DUMP">
                                <UpdateTaskProgress name="UP_DUMP_START" phase="dumping" progress="60.0" message="Dumping phase: Navigating to hopper"/>
                                <SetGoalToHopper goal="{hopper_goal}"/>
                                <!-- Parallel Navigation and Arm Raising -->
                                <Parallel name="PARALLEL_DUMP_NAV_AND_RAISE" success_count="-1" failure_count="1">
                                    <!-- Branch 1: Navigate to the hopper (with quality check) -->
                                    <SubTree ID="SafeNavigate" goal="{hopper_goal}" status="1"/>
                                    
                                    <!-- Branch 2: Raise the arm on approach -->
                                    <Sequence name="SEQ_RAISE_ARM_ON_APPROACH">
                                        <WaitForPlanningFeedback timeout="20.5"/>
                                        <CheckDistanceThreshold name="CH_RAISE_DIST" threshold_name="raise_arm_distance"/>
                                        <SetArmBucketState name="SetABS_4" code="4"/>
                                        <!-- Guard: Fail if arm is not raised by the guard distance -->
                                        <Fallback name="GUARD_RAISE_ARM">
                                            <WaitForArmBucketCompletion name="WaitABS_4" timeout_s="0" message="Approaching hopper (<=7m), raising arm"/>
                                            <Sequence>
                                                <CheckDistanceThreshold name="CH_GUARD_4M" threshold_name="dump_guard_distance"/>
                                                <AlwaysFailure/>
                                            </Sequence>
                                        </Fallback>
                                    </Sequence>
                                </Parallel>

                                <!-- After both navigation and arm raising are complete, execute the dump -->
                                <Sequence name="SEQ_DUMP_ON_ARRIVAL">
                                    <SetArmBucketState name="SetABS_6" code="6"/>
                                    <WaitForArmBucketCompletion name="WaitABS_6" timeout_s="0" message="Arrived at hopper, executing dump"/>
                                </Sequence>

                            </Sequence>

                            <!-- E: After dumping, decide next step -->
                            <Fallback name="FALLBACK_AFTER_DUMP">
                                <!-- E.1: If there is a new task, prepare for it -->
                                <Sequence name="SEQ_HAS_NEXT_TASK">
                                    <CheckForNextCycle name="CheckForNextCycle"/>
                                    <GetAndSetCurrentTask name="GetNextTask"/>
                                    <RequestScoopPoint name="RequestNextScoopPoint"/>
                                </Sequence>

                                <!-- E.2: If there are no new tasks, go to park -->
                                <Sequence name="SEQ_NO_NEXT_TASK">
                                    <Parallel name="PARALLEL_NAV_AND_LOWER_ARM_PARK" success_count="-1" failure_count="1">
                                        <!-- Navigate to the parking spot -->
                                        <Sequence name="SEQ_NAV_TO_PARK">
                                            <SetGoalToParking goal="{park_goal}"/>
                                            <SubTree ID="SafeNavigate" goal="{park_goal}" status="2"/>
                                            <!-- After arrival at park: reset arm and bucket to code=1 and wait for completion -->
                                            <SetArmBucketState name="SetABS_1_Park" code="1"/>
                                            <WaitForArmBucketCompletion name="WaitABS_1_Park" timeout_s="0" message="Arrived at park, resetting arm and bucket (code=1)"/>
                                            <!-- All tasks are complete. Park and wait indefinitely for new instructions or shutdown. -->
                                            <WaitForManualIntervention/>
                                        </Sequence>
                                        <!-- Lower the arm after leaving the hopper -->
                                        <Sequence name="SEQ_LOWER_ARM_WHILE_NAV_PARK">
                                            <CheckDistanceFromLastHopper distance_gt="7.0"/>
                                            <SetArmBucketState code="5"/>
                                            <WaitForArmBucketCompletion message="Lowering arm while returning to park"/>
                                        </Sequence>
                                    </Parallel>
                                </Sequence>
                            </Fallback>
                        </Sequence>
                    </KeepRunningUntilFailure>
                </Sequence>

                <!-- If no tasks, remain idle -->
                <UpdateTaskProgress name="IdleStatus" phase="idle" progress="100.0" message="Idle, waiting for tasks"/>
            </Fallback>

        </ReactiveFallback>
    </BehaviorTree>

</root>
