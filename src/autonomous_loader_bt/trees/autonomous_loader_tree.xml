<?xml version="1.0"?>
<root BTCPP_format="4" main_tree_to_execute="AutonomousLoaderTree">

    <BehaviorTree ID="SafeNavigate">
        <Sequence>
            <RetryUntilSuccessful num_attempts="-1">
                <Sequence>
                    <Sequence>
                        <ResetNavigationArrived/>
                        <ResetDistanceToGoal/>
                        <ResetDistanceReduction/>
                        <ResetPlanningFeedback/>
                    </Sequence>

                    <Fallback>
                        <Parallel success_count="2" failure_count="1">
                            <Sequence>
                                <WaitForPlanningFeedback timeout="300"/>
                                <WaitForNavigationResult
                                    success="{success}"
                                    final_distance_error="{dist_error}"
                                    final_angle_error="{angle_error}"
                                    error_code="{error_code}"
                                    error_msg="{error_msg}"/>
                            </Sequence>
                            <Sequence>
                                <Sleep msec="50"/>
                                <SendNavigationGoal goal="{goal}" status="{status}"/>
                            </Sequence>
                        </Parallel>
                        <Sequence>
                            <SetWorkState value="6"/>
                            <SubTree ID="ManualOverride"
                                     phase="Navigation"
                                     message="Path planning failed. Please move the vehicle manually to a suitable position and click complete."
                                     override_timeout="600"/>
                        </Sequence>
                    </Fallback>

                    <Fallback>
                        <BlackboardCheck key="success" expected="true"/>
                        <Sequence>
                            <CheckErrorCode error_code="{error_code}" recoverable_codes="102,103,104"/>
                            <AlwaysFailure/>
                        </Sequence>
                        <Sequence>
                            <SetWorkState value="6"/>
                            <RequestManualIntervention message="{error_msg}"/>
                            <Fallback>
                                <WaitForManualIntervention/>
                                <Sequence>
                                    <CheckEndTask/>
                                    <AlwaysFailure/>
                                </Sequence>
                            </Fallback>
                            <AlwaysFailure/>
                        </Sequence>
                    </Fallback>

                    <Fallback>
                        <Inverter>
                            <CheckNavStatus status="{status}" expected="1"/>
                        </Inverter>
                        <Fallback>
                            <CheckArrivalQuality distance_error="{dist_error}" angle_error="{angle_error}"/>
                            <Sequence>
                                <SetWorkState value="6"/>
                                <RequestManualIntervention message="Dumping arrival quality is poor. Please intervene."/>
                                <Fallback>
                                    <WaitForManualIntervention/>
                                </Fallback>
                            </Sequence>
                        </Fallback>
                    </Fallback>
                </Sequence>
            </RetryUntilSuccessful>
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="AutonomousLoaderTree">
        <ReactiveFallback name="ROOT">

            <Sequence name="SEQ_CANCEL_TASK">
                <CheckCancelTask/>
                <CancelNavigation/>
                <Sleep msec="500"/>
                <CancelArmBucketAction/>

                <ResetPlanningFeedback/>
                <ResetNavigationArrived/>
                <ResetDistanceToGoal/>
                <ResetDistanceReduction/>
                <ClearCurrentTask/>

                <SetWorkState value="1"/>
                <Script code="arm_on_ground:=true"/>
                <UpdateTaskProgress phase="canceled" progress="0.0" message="Task canceled by scheduler, system reset"/>
            </Sequence>

            <Sequence name="SEQ_PAUSE">
                <CheckPauseTask name="CheckPauseTask"/>
                <PauseNavigation name="PauseNavigation"/>
                <UpdateTaskProgress name="PauseProgress" phase="paused" progress="0.0" message="Task paused"/>
            </Sequence>

            <Sequence name="SEQ_OBSTACLE_AVOID">
                <CheckObstacleTriggered/>
                <HornAndHazard/>
                <SetObstacleTarget/>
                <NavigateToObstacle/>
                <WaitForRestore/>
                <HazardLightsOff/>
                <ClearRestoreRequested/>
            </Sequence>

            <Fallback name="SEL_WORK_IDLE">
                <KeepRunningUntilFailure name="MainWorkLoop">
                    <Sequence name="SEQ_TASK_ROUTING">
                        
                        <RetryUntilSuccessful num_attempts="-1" name="WAIT_FOR_COMMAND">
                            <Fallback>
                                <CheckStartTask name="CheckStartTask"/>
                                <CheckNewTask name="CheckNewTask"/>
                                <CheckEndTask name="CheckEndTask"/>
                                <Sequence>
                                    <Sleep msec="200"/>
                                    <AlwaysFailure/>
                                </Sequence>
                            </Fallback>
                        </RetryUntilSuccessful>
                        
                        <Fallback name="ROUTE_DECISION">
                            
                            <Sequence name="ROUTE_PARK">
                                <CheckEndTask/>
                                <CommitToEndMission/>
                                <Script code="just_left_hopper:=false"/>
                                <Script code="arm_lowered_on_retreat:=false"/>

                                <Parallel name="PARALLEL_SAFE_QUIT_MISSION" success_count="1" failure_count="1">
                                    
                                    <Sequence name="SEQ_NAV_TO_PARK">
                                        <SetWorkState value="7"/>
                                        <SetGoalToParking goal="{parking_goal}"/>
                                        
                                        <SubTree ID="SafeNavigate" goal="{parking_goal}" status="2"/>
                                        
                                        <SetArmBucketState name="SetABS_1_End" code="1"/>
                                        <WaitForArmBucketCompletion name="WaitABS_1_End" timeout_s="300" message="Mission ended, resetting arm and bucket"/>

                                        <SetWorkState value="8"/>
                                        <Script code="arm_on_ground:=true"/>
                                        <UpdateTaskProgress name="StopProgress" phase="stopped" progress="100.0" message="Mission ended, returned to park and reset."/>
                                        
                                        <AlwaysSuccess/>
                                    </Sequence>

                                    <Sequence name="SEQ_FINAL_LOWER_ARM_GROUND">
                                        <RetryUntilSuccessful num_attempts="-1">
                                            <Fallback>
                                                <Sequence>
                                                    <Sleep msec="100"/> <BlackboardCheck key="arm_lowered_on_retreat" expected="false"/>
                                                    
                                                    <CheckDistanceFromLastHopper threshold_name="retract_arm_distance"/>
                                                    
                                                    <SetArmBucketState code="5"/>
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Drove 9m away from hopper, lowering arm to ground during transit"/>
                                                    <Script code="arm_lowered_on_retreat:=true"/>
                                                    <AlwaysFailure/> 
                                                </Sequence>
                                                <Sequence>
                                                    <Sleep msec="500"/>
                                                    <AlwaysFailure/> 
                                                </Sequence>
                                            </Fallback>
                                        </RetryUntilSuccessful>
                                    </Sequence>
                                </Parallel>
                            </Sequence>

                            <Sequence name="ROUTE_WORK">
                                
                                <GetAndSetCurrentTask name="GetAndSetCurrentTask"/>

                                <Fallback name="FALLBACK_PREPARE_ARM_BEFORE_SCOOP">
                                    <Sequence name="SEQ_CHECK_IF_CONTINUOUS">
                                        <BlackboardCheck key="arm_on_ground" expected="false"/>
                                    </Sequence>
                                    <Sequence name="SEQ_PREPARE_ARM_FORCE">
                                        <SetArmBucketState name="SetABS_2_Prepare" code="2"/>
                                        <WaitForArmBucketCompletion name="WaitABS_2_Prepare" timeout_s="300" message="Bucket on ground, preparing arm before moving"/>
                                        <Script code="arm_on_ground:=false"/>
                                    </Sequence>
                                </Fallback>

                                <Fallback name="FALLBACK_SET_WORK_STATE_BY_TYPE">
                                    <Sequence name="SEQ_SET_STATE_TEMPORARY">
                                        <CheckArmBucketDone name="CheckIfTempTask" expect_code="1"/> 
                                        <SetWorkState value="3"/> 
                                    </Sequence>
                                    <Sequence name="SEQ_SET_STATE_AUTOMATIC">
                                        <SetWorkState value="2"/> 
                                    </Sequence>
                                </Fallback>

                                <Sequence name="SEQ_SCOOP_POINT_NAV">
                                    <UpdateTaskProgress name="UP_SCP_REQ" phase="scooping" progress="20.0" message="Requesting scoop point"/>
                                    <RequestScoopPoint name="RequestScoopPoint"/>

                                    <Fallback name="SEL_HANDLE_SCOOP_POINT">
                                        <Sequence name="SEQ_ZERO_CASE">
                                            <CheckScoopPointZero name="CheckScoopPointZero"/>
                                            <SetGoalToBinCenter goal="{bin_center_goal}"/>
                                            <SubTree ID="SafeNavigate" goal="{bin_center_goal}" status="0"/>
                                            <SetPointAccumulationStart name="StartAccumulation"/>
                                            <WaitForPointAccumulationDone name="WaitAccumulation" timeout_s="300" message="Arrived at bin center, waiting for point cloud calculation"/>
                                            <RequestScoopPoint name="RequestScoopPoint_Again"/>
                                        </Sequence>
                                        <Inverter><CheckScoopPointZero/></Inverter>
                                    </Fallback>

                                    <SetGoalToScoopPoint goal="{scoop_point_goal}"/>
                                </Sequence>

                                <Parallel name="PARALLEL_NAV_AND_SCOOP_ACTIONS" success_count="-1" failure_count="1">
                                    <SubTree ID="SafeNavigate" goal="{scoop_point_goal}" status="0"/>

                                    <Sequence name="SEQ_SCOOP_ACTIONS_ON_APPROACH">
                                        <Fallback>
                                            <RetryUntilSuccessful num_attempts="3">
                                                <WaitForPlanningFeedback timeout="300"/>
                                            </RetryUntilSuccessful>
                                            <RetryUntilSuccessful num_attempts="-1">
                                                <Sequence>
                                                    <SetWorkState value="6"/>
                                                    <RequestManualIntervention message="Planning to scoop failed, please intervene"/>
                                                    <WaitForManualIntervention/>
                                                    <ResetPlanningFeedback/>
                                                    <AlwaysFailure/> 
                                                </Sequence>
                                            </RetryUntilSuccessful>
                                        </Fallback>

                                        <Fallback name="FALLBACK_LOWER_ARM_LEAVING_HOPPER">
                                            <Sequence name="SEQ_LOWER_ARM_TRANSIT">
                                                <BlackboardCheck key="just_left_hopper" expected="true"/>
                                                <CheckDistanceFromLastHopper threshold_name="retract_arm_distance"/>
                                                <Inverter><CheckArmBucketDone expect_code="5"/></Inverter>
                                                <SetArmBucketState code="5"/>
                                                <WaitForArmBucketCompletion timeout_s="300" message="Leaving hopper, lowering arm"/>
                                                <Script code="just_left_hopper:=false"/>
                                            </Sequence>
                                            <AlwaysSuccess/>
                                        </Fallback>

                                        <Fallback>
                                            <CheckArmBucketDone expect_code="3"/>
                                            <Sequence>
                                                <CheckDistanceThreshold threshold_name="lower_bucket_distance"/>
                                                <SetArmBucketState code="3"/>
                                                <WaitForArmBucketCompletion timeout_s="300" message="Approaching scoop point, lowering bucket"/>
                                            </Sequence>
                                        </Fallback>

                                        <Fallback>
                                            <CheckArmBucketDone expect_code="7"/>
                                            <Sequence>
                                                <WaitForNavigationArrival message="Waiting nav arrival to scoop"/>
                                                <CheckDistanceThreshold threshold_name="stop_scoop_distance"/>
                                                <SetArmBucketState code="7"/>
                                                <Fallback>
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Arrived at scoop point, scooping"/>
                                                    <Sequence>
                                                        <SetWorkState value="4"/>
                                                        <RequestManualIntervention message="Scooping action failed, vehicle stopped"/>
                                                        <WaitForManualIntervention/>
                                                        <AlwaysFailure/>
                                                    </Sequence>
                                                </Fallback>
                                            </Sequence>
                                        </Fallback>
                                        <AlwaysSuccess/>
                                    </Sequence>
                                </Parallel>

                                <Sequence name="SEQ_DUMP">
                                    <UpdateTaskProgress name="UP_DUMP_START" phase="dumping" progress="60.0" message="Dumping phase: Navigating to hopper"/>
                                    <SetGoalToHopper goal="{hopper_goal}"/>
                                    <StartPointAccumulation/>
                                    
                                    <Parallel name="PARALLEL_DUMP_NAV_AND_MANAGE_ACCUMULATION" success_count="-1" failure_count="1">
                                        <Parallel name="PARALLEL_DUMP_NAV_AND_RAISE" success_count="-1" failure_count="1">
                                            <RetryUntilSuccessful num_attempts="-1">
                                                <Sequence>
                                                    <SubTree ID="SafeNavigate" goal="{hopper_goal}" status="1"/>
                                                </Sequence>
                                            </RetryUntilSuccessful>

                                            <Sequence name="SEQ_RAISE_ARM_ON_APPROACH">
                                                <Fallback>
                                                    <RetryUntilSuccessful num_attempts="3">
                                                        <WaitForPlanningFeedback timeout="300"/>
                                                    </RetryUntilSuccessful>
                                                    <RetryUntilSuccessful num_attempts="-1">
                                                        <Sequence>
                                                            <SetWorkState value="6"/>
                                                            <RequestManualIntervention message="Planning to hopper failed, please intervene"/>
                                                            <WaitForManualIntervention/>
                                                            <ResetPlanningFeedback/>
                                                            <AlwaysFailure/> 
                                                        </Sequence>
                                                    </RetryUntilSuccessful>
                                                </Fallback>

                                                <CheckDistanceThreshold threshold_name="raise_arm_distance"/>
                                                <SetArmBucketState code="4"/>
                                                <Fallback>
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Approaching hopper, raising arm"/>
                                                    <RetryUntilSuccessful num_attempts="-1">
                                                        <Sequence>
                                                            <SetWorkState value="4"/>
                                                            <RequestManualIntervention message="Arm raise timeout, vehicle stopped"/>
                                                            <WaitForManualIntervention/>
                                                        </Sequence>
                                                    </RetryUntilSuccessful>
                                                </Fallback>
                                            </Sequence>
                                        </Parallel>

                                        <Sequence name="SEQ_STOP_ACCUMULATION_ON_DISTANCE">
                                            <CheckDistanceSinceScoop threshold_name="stop_accumulation_distance"/>
                                            <StopPointAccumulation/>
                                        </Sequence>

                                        <Sequence name="SEQ_SET_STATE_7_ON_RETREAT">
                                            <CheckDistanceSinceScoop threshold_name="retreat_check_distance"/>
                                            <SetArmBucketState code="8"/>
                                            <WaitForArmBucketCompletion timeout_s="300" message="Retreated from scoop, waiting for transit pose"/>
                                        </Sequence>
                                    </Parallel>

                                    <Sequence name="SEQ_DUMP_ON_ARRIVAL">
                                        <SetArmBucketState name="SetABS_6" code="6"/>
                                        <WaitForArmBucketCompletion name="WaitABS_6" timeout_s="300" message="Arrived at hopper, executing dump"/>
                                    </Sequence>
                                </Sequence>

                                <Sequence name="SEQ_AFTER_CYCLE_DONE">
                                    <SetWorkState value="1"/>
                                    <Script code="just_left_hopper:=true"/>
                                </Sequence>

                            </Sequence> </Fallback> </Sequence>
                </KeepRunningUntilFailure>

                <Sequence>
                    <SetWorkState value="1"/>
                    <UpdateTaskProgress name="IdleStatus" phase="idle" progress="100.0" message="Idle, waiting for tasks"/>
                </Sequence>
            </Fallback>

        </ReactiveFallback>
    </BehaviorTree>

</root>