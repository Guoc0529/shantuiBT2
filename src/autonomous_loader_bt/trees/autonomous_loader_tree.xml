<?xml version="1.0"?>
<!--
  自主装载行为树 (Autonomous Loader Behavior Tree)
  ================================================
  功能描述: 露天矿无人驾驶电动轮自卸车的自主铲装-卸料循环作业控制
  主要流程: 空闲等待 → 接收任务 → 前往铲装点 → 铲装 → 前往卸料点 → 卸料 → 返回循环

  状态值定义 (SetWorkState):
    1: 空闲/待机 (Idle)
    2: 前往铲装点 (Going to scoop point)
    4: 动作执行中 (Action in progress - scoop/dump)
    6: 人工干预等待中 (Manual intervention required)
    7: 返回停车场 (Returning to parking)
    8: 任务结束 (Mission ended)

  导航状态定义 (NavigationStatus):
    0: SCOOP  - 铲装阶段导航
    1: DUMP   - 卸料阶段导航
    2: OTHER  - 其他导航（如停车场）

  黑板变量:
    arm_on_ground: 机械臂是否在地面
    just_left_hopper: 是否刚从卸料仓离开
    arm_lowered_on_retreat: 撤退时机械臂是否已放下
    goal: 当前导航目标点
    success: 导航是否成功
    status: 当前导航状态
    error_code: 导航错误码
    error_msg: 导航错误信息
    dist_error: 最终距离误差
    angle_error: 最终角度误差
    parking_goal: 停车场目标点
    scoop_point_goal: 铲装点目标
    hopper_goal: 卸料仓目标点
    bin_center_goal: 料仓中心目标点
-->
<root BTCPP_format="4" main_tree_to_execute="AutonomousLoaderTree">

    <!--
      ================================================================
      SafeNavigate 子树: 通用安全导航子树
      ================================================================
      功能: 执行带错误处理和安全检查的导航任务
      参数:
        goal: 导航目标点 (输入)
        status: 导航状态 (输入, 参考 NavigationStatus 枚举)
        success: 导航是否成功 (输出)
        error_code: 导航错误码 (输出)
        error_msg: 导航错误信息 (输出)
        dist_error: 距离误差 (输出)
        angle_error: 角度误差 (输出)

      错误处理策略:
        1. 路径规划失败 → 请求人工接管移动到合适位置
        2. 可恢复错误码(102,103,104) → 请求人工干预
        3. 到达质量差 → 请求人工干预
        4. 正常到达 → 验证到达质量
    -->
    <BehaviorTree ID="SafeNavigate">
        <Sequence>

            <!-- Step 1: 重置所有状态标志 -->
            <Sequence>
                <ResetNavigationArrived/>
                <ResetDistanceToGoal/>
                <ResetDistanceReduction/>
                <ResetPlanningFeedback/>
            </Sequence>

            <!-- Step 2: 发送导航目标并等待结果 -->
            <Sequence>
                <!-- 发送导航目标(只发送一次) -->
                <SendNavigationGoal goal="{goal}" status="{status}"/>
                <!-- 等待导航结果 -->
                <WaitForNavigationResult
                    success="{success}"
                    final_distance_error="{dist_error}"
                    final_angle_error="{angle_error}"
                    error_code="{error_code}"
                    error_msg="{error_msg}"/>
            </Sequence>

            <!-- Step 3: 错误码检查与处理 -->
            <Fallback>
                <!-- 成功则继续 -->
                <BlackboardCheck key="success" expected="true"/>
                <!-- 检查是否为可恢复错误 -->
                <Sequence>
                    <CheckErrorCode error_code="{error_code}" recoverable_codes="102,103,104"/>
                    <AlwaysFailure/>
                </Sequence>
                <!-- 不可恢复错误: 请求人工干预 -->
                <Sequence>
                    <!-- <SetWorkState value="6"/> -->
                    <RequestManualIntervention message="{error_msg}"/>
                    <Fallback>
                        <WaitForManualIntervention/>
                        <Sequence>
                            <CheckEndTask/>
                            <AlwaysFailure/>
                        </Sequence>
                    </Fallback>
                    <AlwaysFailure/>
                </Sequence>
            </Fallback>

            <!-- Step 4: 到达质量验证 -->
            <Fallback>
                <!-- 检查导航状态是否为预期的状态 -->
                <Inverter>
                    <CheckNavStatus status="{status}" expected="1"/>
                </Inverter>
                <!-- 到达质量检查 -->
                <Fallback>
                    <CheckArrivalQuality distance_error="{dist_error}" angle_error="{angle_error}"/>
                    <!-- 到达质量差: 请求人工干预 -->
                    <Sequence>
                        <!-- <SetWorkState value="6"/> -->
                        <RequestManualIntervention message="Dumping arrival quality is poor. Please intervene."/>
                        <Fallback>
                            <WaitForManualIntervention/>
                        </Fallback>
                    </Sequence>
                </Fallback>
            </Fallback>
        </Sequence>
    </BehaviorTree>

    <!--
      ================================================================
      AutonomousLoaderTree 主行为树
      ================================================================
      功能: 自主装载机的完整作业控制
      结构: ReactiveFallback 实现并行条件检查

      ReactiveFallback 策略(优先级从高到低):
        1. ctrlCmd=3 即时响应 (CheckCtrl3Immediate) - 立即鸣笛双闪
        2. 遥控接管处理 (SEQ_REMOTE_CONTROL)
        3. 取消任务 (SEQ_CANCEL_TASK)
        4. 暂停任务 (SEQ_PAUSE)
        5. 障碍物避让 (SEQ_OBSTACLE_AVOID)
        6. 正常作业循环 (MainWorkLoop)
        7. 空闲待机 (Idle)
    -->
    <BehaviorTree ID="AutonomousLoaderTree">
        <ReactiveFallback name="ROOT">

            <!--
              ==============================================================
              ctrlCmd=3 即时响应 (最高优先级)
              ==============================================================
              收到 ctrlCmd=3 时立即鸣笛+双闪（不受其他状态影响）
              注意：此节点会阻塞其他动作执行约2秒
            -->
            <CheckCtrl3Immediate/>

            <!--
              ==============================================================
              遥控接管处理序列 (RemoteControlHandler)
              ==============================================================
              监听 vcu_drive_mode:
                - 变为2(遥控): 保存快照 + 发急停
                - 变为1(自动): 检测恢复条件并处理
              处理策略:
                - 状态1或8: 直接解除急停
                - 位置偏差≤0.5m: 直接解除急停
                - 位置偏差>0.5m: 发送taskID=0取消任务，等待空闲后解除急停
            -->
            <Sequence name="SEQ_REMOTE_CONTROL">
                <VcuDriveModeListener/>

                <!-- 遥控接管时: 保存快照并急停 -->
                <SaveRemoteControlSnapshot/>

                <!-- 等待退出遥控模式 -->
                <CheckRemoteControlRecovery/>

                <!-- 恢复处理 -->
                <RecoverFromRemoteControl timeout="30"/>
            </Sequence>

            <!--
              ==============================================================
              SEQ_CANCEL_TASK: 取消任务序列
              ==============================================================
              触发条件: CheckCancelTask 返回成功
              执行动作: 取消导航、重置状态、清空任务、机械臂归位
              结果: 工作状态设为1(空闲), 机械臂放地面
            -->
            <Sequence name="SEQ_CANCEL_TASK">
                <CheckCancelTask/>
                <CancelNavigation/>
                <Sleep msec="500"/>
                <CancelArmBucketAction/>

                <!-- 重置所有导航和任务状态 -->
                <ResetPlanningFeedback/>
                <ResetNavigationArrived/>
                <ResetDistanceToGoal/>
                <ResetDistanceReduction/>
                <ClearCurrentTask/>

                <!-- 状态重置 -->
                <SetWorkState value="1"/>
                <Script code="arm_on_ground:=true"/>
                <UpdateTaskProgress phase="canceled" progress="0.0" message="Task canceled by scheduler, system reset"/>
            </Sequence>

            <!--
              ==============================================================
              SEQ_PAUSE: 暂停任务序列
              ==============================================================
              触发条件: CheckPauseTask 返回成功
              执行动作: 暂停导航、更新进度为暂停状态
            -->
            <Sequence name="SEQ_PAUSE">
                <CheckPauseTask name="CheckPauseTask"/>
                <PauseNavigation name="PauseNavigation"/>
                <UpdateTaskProgress name="PauseProgress" phase="paused" progress="0.0" message="Task paused"/>
            </Sequence>

<!--
              ==============================================================
              SEQ_OBSTACLE_AVOID: 障碍物避让与安全待机序列
              ==============================================================
            -->
            <Sequence name="SEQ_OBSTACLE_AVOID">
                <CheckObstacleTriggered/>
                <SetWorkState value="5"/>
                <SetObstacleTarget/>
                
                <Script code="arm_lowered_on_retreat:=false"/>

                <!-- 🌟 核心修复：避障发车前，彻底清空上一次任务残留的里程表和到达标记！ -->
                <ResetNavigationArrived/>
                <ResetDistanceToGoal/>
                <ResetDistanceReduction/>

                <!-- 并行控制组：主执行流与途中安全降臂监控 -->
                <Parallel name="PARALLEL_OBSTACLE_NAV_AND_SAFE_ARM" success_count="1" failure_count="1">
                    
                    <!-- 1. 主执行序列 -->
                    <Sequence name="SEQ_OBSTACLE_MAIN_FLOW">
                        <NavigateToObstacle/>
                        
                        <SetArmBucketState code="1"/>
                        <WaitForArmBucketCompletion timeout_s="300" message="Arrived at obstacle point, lowering bucket to ground for safe standby"/>
                        
                        <Script code="arm_on_ground:=true"/>
                        
                        <WaitForRestore/>
                        
                        <HazardLightsOff/>
                        <ClearRestoreRequested/>
                        <SetWorkState value="1"/>
                        <AlwaysSuccess/>
                    </Sequence>

                    <!-- 2. 途中安全降大臂监控序列 -->
                    <Sequence name="SEQ_OBSTACLE_ARM_MONITOR_TRANSIT">
                        <RetryUntilSuccessful num_attempts="-1">
                            <Fallback>
                                <Sequence>
                                    <Sleep msec="100"/>
                                    <BlackboardCheck key="just_left_hopper" expected="true"/>
                                    <BlackboardCheck key="arm_lowered_on_retreat" expected="false"/>
                                    
                                    <!-- 这里的 9 米现在会从真正的 0 开始重新计算了！ -->
                                    <CheckDistanceFromLastHopper threshold_name="retract_arm_distance"/>
                                    
                                    <SetArmBucketState code="5"/>
                                    <WaitForArmBucketCompletion timeout_s="300" message="Drove 9m away from hopper during obstacle avoidance, lowering arm safely in transit"/>
                                    
                                    <Script code="arm_lowered_on_retreat:=true"/>
                                    <Script code="just_left_hopper:=false"/>
                                    <AlwaysFailure/>
                                </Sequence>
                                <Sequence>
                                    <Sleep msec="500"/>
                                    <AlwaysFailure/>
                                </Sequence>
                            </Fallback>
                        </RetryUntilSuccessful>
                    </Sequence>
                </Parallel>
            </Sequence>

            <!--
              ==============================================================
              SEL_WORK_IDLE: 工作/空闲选择器
              ==============================================================
              优先级:
                1. MainWorkLoop: 正常作业循环(失败则保持运行)
                2. Idle: 空闲待机状态

              KeepRunningUntilFailure: 确保主循环持续运行直到失败
            -->
            <Fallback name="SEL_WORK_IDLE">
                <KeepRunningUntilFailure name="MainWorkLoop">
                    <Sequence name="SEQ_TASK_ROUTING">

                        <!--
                          ==============================================================
                          WAIT_FOR_COMMAND: 等待任务指令
                          ==============================================================
                          重试直到收到有效指令:
                            - CheckStartTask: 开始新任务
                            - CheckNewTask: 切换新任务
                            - CheckEndTask: 结束任务
                            - 否则持续等待(200ms间隔)
                        -->
                        <RetryUntilSuccessful num_attempts="-1" name="WAIT_FOR_COMMAND">
                            <Fallback>
                                <!-- 如果在空闲状态下发现了待执行的避障/停车指令，立刻将其激活！ -->
                                <Sequence>
                                    <CheckObstaclePending/>
                                    <ActivateObstaclePending/>
                                    <AlwaysFailure/> <!-- 强制返回失败，让根节点的 ReactiveFallback 瞬间接管去避障 -->
                                </Sequence>

                                <CheckStartTask name="CheckStartTask"/>
                                <CheckNewTask name="CheckNewTask"/>
                                <CheckEndTask name="CheckEndTask"/>
                                <Sequence>
                                    <Sleep msec="200"/>
                                    <AlwaysFailure/>
                                </Sequence>
                            </Fallback>
                        </RetryUntilSuccessful>

                        <!--
                          ==============================================================
                          ROUTE_DECISION: 任务路由决策
                          ==============================================================
                          Fallback策略: 按顺序尝试每个分支,第一个成功即执行
                        -->
                        <Fallback name="ROUTE_DECISION">

                            <!--
                              ==============================================================
                              ROUTE_PARK: 结束任务 → 返回停车场
                              ==============================================================
                              触发条件: CheckEndTask 返回成功
                              执行流程:
                                1. 提交结束任务
                                2. 并行执行:
                                  - 导航到停车场
                                  - 行驶9m后自动放下机械臂
                                3. 到达后复位机械臂和铲斗
                                4. 更新任务进度为完成
                            -->
                            <Sequence name="ROUTE_PARK">
                                <CheckEndTask/>
                                <CommitToEndMission/>
                                <Script code="just_left_hopper:=false"/>
                                <Script code="arm_lowered_on_retreat:=false"/>

                                <!-- 并行: 导航到停车场 + 行驶中自动放臂 -->
                                <Parallel name="PARALLEL_SAFE_QUIT_MISSION" success_count="1" failure_count="1">

                                    <!-- 导航到停车场 -->
                                    <Sequence name="SEQ_NAV_TO_PARK">
                                        <SetWorkState value="7"/>
                                        <SetGoalToParking goal="{parking_goal}"/>

                                        <!-- 安全导航到停车场(status=2=OTHER) -->
                                        <SubTree ID="SafeNavigate" goal="{parking_goal}" status="2"/>

                                        <!-- 任务结束: 复位铲斗状态 -->
                                        <SetArmBucketState name="SetABS_1_End" code="1"/>
                                        <WaitForArmBucketCompletion name="WaitABS_1_End" timeout_s="300" message="Mission ended, resetting arm and bucket"/>

                                        <!-- 完成任务 -->
                                        <SetWorkState value="8"/>
                                        <Script code="arm_on_ground:=true"/>
                                        <UpdateTaskProgress name="StopProgress" phase="stopped" progress="100.0" message="Mission ended, returned to park and reset."/>

                                        <AlwaysSuccess/>
                                    </Sequence>

                                    <!-- 行驶中自动放臂 -->
                                    <Sequence name="SEQ_FINAL_LOWER_ARM_GROUND">
                                        <RetryUntilSuccessful num_attempts="-1">
                                            <Fallback>
                                                <Sequence>
                                                    <Sleep msec="100"/>
                                                    <!-- 检查臂是否还没放下 -->
                                                    <BlackboardCheck key="arm_lowered_on_retreat" expected="false"/>

                                                    <!-- 检查是否远离了上一个卸料仓 -->
                                                    <CheckDistanceFromLastHopper threshold_name="retract_arm_distance"/>

                                                    <!-- 放下机械臂 -->
                                                    <SetArmBucketState code="5"/>
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Drove 9m away from hopper, lowering arm to ground during transit"/>
                                                    <Script code="arm_lowered_on_retreat:=true"/>
                                                    <AlwaysFailure/>
                                                </Sequence>
                                                <!-- 继续等待 -->
                                                <Sequence>
                                                    <Sleep msec="500"/>
                                                    <AlwaysFailure/>
                                                </Sequence>
                                            </Fallback>
                                        </RetryUntilSuccessful>
                                    </Sequence>
                                </Parallel>
                            </Sequence>

                            <!--
                              ==============================================================
                              ROUTE_WORK: 正常作业循环
                              ==============================================================
                              完整作业流程:
                                1. 获取任务
                                2. 准备机械臂
                                3. 前往铲装点 → 铲装
                                4. 前往卸料点 → 卸料
                                5. 循环
                            -->
                            <Sequence name="ROUTE_WORK">

                                <!-- 获取并设置当前任务 -->
                                <GetAndSetCurrentTask name="GetAndSetCurrentTask"/>

                                <!--
                                  ==============================================================
                                  准备机械臂
                                  ==============================================================
                                  Fallback策略:
                                    - 如果臂已在地面(arm_on_ground=false)则跳过
                                    - 否则强制将臂设为准备状态(code=2)
                                -->
                                <Fallback name="FALLBACK_PREPARE_ARM_BEFORE_SCOOP">
                                    <Sequence name="SEQ_CHECK_IF_CONTINUOUS">
                                        <BlackboardCheck key="arm_on_ground" expected="false"/>
                                    </Sequence>
                                    <Sequence name="SEQ_PREPARE_ARM_FORCE">
                                        <SetArmBucketState name="SetABS_2_Prepare" code="2"/>
                                        <WaitForArmBucketCompletion name="WaitABS_2_Prepare" timeout_s="300" message="Bucket on ground, preparing arm before moving"/>
                                        <Script code="arm_on_ground:=false"/>
                                    </Sequence>
                                </Fallback>

                                <!-- 设置工作状态: 前往铲装点 -->
                                <SetWorkState/>

                                <!--
                                  ==============================================================
                                  SEQ_SCOOP_POINT_NAV: 铲装点导航
                                  ==============================================================
                                  流程:
                                    1. 请求铲装点坐标
                                    2. 处理特殊情况(点数为0)
                                    3. 设置铲装点为目标
                                -->
                                <Sequence name="SEQ_SCOOP_POINT_NAV">
                                    <UpdateTaskProgress name="UP_SCP_REQ" phase="scooping" progress="20.0" message="Requesting scoop point"/>
                                    <RequestScoopPoint name="RequestScoopPoint"/>

                                    <!-- 处理铲装点 -->
                                    <Fallback name="SEL_HANDLE_SCOOP_POINT">
                                        <!-- 点数为0的特殊情况 -->
                                        <Sequence name="SEQ_ZERO_CASE">
                                            <CheckScoopPointZero name="CheckScoopPointZero"/>
                                            <!-- 先导航到料仓中心计算点云 -->
                                            <SetGoalToBinCenter goal="{bin_center_goal}"/>
                                            <SubTree ID="SafeNavigate" goal="{bin_center_goal}" status="0"/>
                                            <!-- 开始累积点云 -->
                                            <SetPointAccumulationStart name="StartAccumulation"/>
                                            <WaitForPointAccumulationDone name="WaitAccumulation" timeout_s="300" message="Arrived at bin center, waiting for point cloud calculation"/>
                                            <!-- 重新请求铲装点 -->
                                            <RequestScoopPoint name="RequestScoopPoint_Again"/>
                                        </Sequence>
                                        <Inverter><CheckScoopPointZero/></Inverter>
                                    </Fallback>

                                    <!-- 设置铲装点为导航目标 -->
                                    <SetGoalToScoopPoint goal="{scoop_point_goal}"/>
                                </Sequence>

                                <!--
                                  ==============================================================
                                  并行执行: 导航到铲装点 + 沿途执行动作
                                  ==============================================================
                                  Parallel: success_count=-1(全部成功), failure_count=1(任一失败则失败)
                                -->
                                <Parallel name="PARALLEL_NAV_AND_SCOOP_ACTIONS" success_count="-1" failure_count="1">
                                    <!-- 分支1: 安全导航到铲装点(status=0=SCOOP) -->
                                    <SubTree ID="SafeNavigate" goal="{scoop_point_goal}" status="0"/>

                                    <!--
                                      ==============================================================
                                      SEQ_SCOOP_ACTIONS_ON_APPROACH: 接近过程中的动作序列
                                      ==============================================================
                                      沿途根据距离阈值触发不同动作
                                    -->
                                    <Sequence name="SEQ_SCOOP_ACTIONS_ON_APPROACH">
                                        <Fallback>
                                            <!-- 确保路径规划成功(最多重试3次) -->
                                            <RetryUntilSuccessful num_attempts="3">
                                                <WaitForPlanningFeedback timeout="300"/>
                                            </RetryUntilSuccessful>
                                            <!-- 规划失败则请求人工干预 -->
                                            <RetryUntilSuccessful num_attempts="-1">
                                                <Sequence>
                                                    <!-- <SetWorkState value="6"/> -->
                                                    <RequestManualIntervention message="Planning to scoop failed, please intervene"/>
                                                    <WaitForManualIntervention/>
                                                    <ResetPlanningFeedback/>
                                                    <AlwaysFailure/>
                                                </Sequence>
                                            </RetryUntilSuccessful>
                                        </Fallback>

                                        <!--
                                          ==============================================================
                                          离开卸料仓后放下机械臂
                                          ==============================================================
                                          条件: just_left_hopper=true 且 远离卸料仓
                                          动作: 设置铲斗状态为5(放下)
                                        -->
                                        <Fallback name="FALLBACK_LOWER_ARM_LEAVING_HOPPER">
                                            <Sequence name="SEQ_LOWER_ARM_TRANSIT">
                                                <BlackboardCheck key="just_left_hopper" expected="true"/>
                                                <CheckDistanceFromLastHopper threshold_name="retract_arm_distance"/>
                                                <!-- 检查铲斗状态是否为5,不是则设置 -->
                                                <Inverter><CheckArmBucketDone expect_code="5"/></Inverter>
                                                <SetArmBucketState code="5"/>
                                                <WaitForArmBucketCompletion timeout_s="300" message="Leaving hopper, lowering arm"/>
                                                <Script code="just_left_hopper:=false"/>
                                            </Sequence>
                                            <AlwaysSuccess/>
                                        </Fallback>

                                        <!--
                                          ==============================================================
                                          根据距离阈值降低铲斗
                                          ==============================================================
                                          条件: 铲斗状态为3(预挖) 且 到达降斗距离阈值
                                          动作: 设置铲斗状态为3(降低铲斗)
                                        -->
                                        <Fallback>
                                            <CheckArmBucketDone expect_code="3"/>
                                            <Sequence>
                                                <CheckDistanceThreshold threshold_name="lower_bucket_distance"/>
                                                <SetArmBucketState code="3"/>
                                                <WaitForArmBucketCompletion timeout_s="300" message="Approaching scoop point, lowering bucket"/>
                                            </Sequence>
                                        </Fallback>

                                        <!--
                                          ==============================================================
                                          到达铲装点并执行铲装
                                          ==============================================================
                                          条件: 铲斗状态为7 且 到达停铲距离
                                          动作: 设置铲斗状态为7(执行铲装)
                                        -->
                                        <Fallback>
                                            <CheckArmBucketDone expect_code="7"/>
                                            <Sequence>
                                                <!-- 🌟 核心修复：删掉 WaitForNavigationArrival -->
                                                <!-- 让系统直接在这里阻塞，实时监控距离，一旦进入3米范围立刻放行 -->
                                                <CheckDistanceThreshold threshold_name="stop_scoop_distance"/>
                                                
                                                <SetArmBucketState code="7"/>
                                                <Fallback>
                                                    <!-- 这里可以把 message 改一下，因为是提前铲料了 -->
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Distance < 3m, starting to scoop in advance"/>
                                                    <Sequence>
                                                        <SetWorkState value="4"/>
                                                        <RequestManualIntervention message="Scooping action failed, vehicle stopped"/>
                                                        <WaitForManualIntervention/>
                                                        <AlwaysFailure/>
                                                    </Sequence>
                                                </Fallback>
                                            </Sequence>
                                        </Fallback>
                                        <AlwaysSuccess/>
                                    </Sequence>
                                </Parallel>

                                <!--
                                  ==============================================================
                                  SEQ_DUMP: 卸料序列
                                  ==============================================================
                                  流程:
                                    1. 设置目标为卸料仓
                                    2. 并行执行:
                                      - 安全导航到卸料仓
                                      - 接近时升起铲斗
                                      - 根据距离停止点云累积
                                      - 远离后等待点云处理
                                    3. 到达后执行卸料动作
                                -->
                                <Sequence name="SEQ_DUMP">
                                    <UpdateTaskProgress name="UP_DUMP_START" phase="dumping" progress="60.0" message="Dumping phase: Navigating to hopper"/>
                                    <SetGoalToHopper goal="{hopper_goal}"/>
                                    <StartPointAccumulation/>

                                    <!-- 并行: 导航 + 升臂 + 点云管理 -->
                                    <Parallel name="PARALLEL_DUMP_NAV_AND_MANAGE_ACCUMULATION" success_count="-1" failure_count="1">

                                        <!-- 导航 + 升臂 -->
                                        <Parallel name="PARALLEL_DUMP_NAV_AND_RAISE" success_count="-1" failure_count="1">
                                            <!-- 安全导航到卸料仓(status=1=DUMP) -->
                                            <RetryUntilSuccessful num_attempts="-1">
                                                <Sequence>
                                                    <SubTree ID="SafeNavigate" goal="{hopper_goal}" status="1"/>
                                                </Sequence>
                                            </RetryUntilSuccessful>

                                            <!-- 接近过程中升起机械臂 -->
                                            <Sequence name="SEQ_RAISE_ARM_ON_APPROACH">
                                                <Fallback>
                                                    <!-- 确保路径规划成功 -->
                                                    <RetryUntilSuccessful num_attempts="3">
                                                        <WaitForPlanningFeedback timeout="300"/>
                                                    </RetryUntilSuccessful>
                                                    <!-- 规划失败处理 -->
                                                    <RetryUntilSuccessful num_attempts="-1">
                                                        <Sequence>
                                                            <SetWorkState value="6"/>
                                                            <RequestManualIntervention message="Planning to hopper failed, please intervene"/>
                                                            <WaitForManualIntervention/>
                                                            <ResetPlanningFeedback/>
                                                            <AlwaysFailure/>
                                                        </Sequence>
                                                    </RetryUntilSuccessful>
                                                </Fallback>

                                                <!-- 到达升臂距离阈值时升起铲斗 -->
                                                <CheckDistanceThreshold threshold_name="raise_arm_distance"/>
                                                <SetArmBucketState code="4"/>
                                                <Fallback>
                                                    <WaitForArmBucketCompletion timeout_s="300" message="Approaching hopper, raising arm"/>
                                                    <!-- 超时处理 -->
                                                    <RetryUntilSuccessful num_attempts="-1">
                                                        <Sequence>
                                                            <SetWorkState value="4"/>
                                                            <RequestManualIntervention message="Arm raise timeout, vehicle stopped"/>
                                                            <WaitForManualIntervention/>
                                                        </Sequence>
                                                    </RetryUntilSuccessful>
                                                </Fallback>
                                            </Sequence>
                                        </Parallel>

                                        <!-- 行驶一定距离后停止点云累积 -->
                                        <Sequence name="SEQ_STOP_ACCUMULATION_ON_DISTANCE">
                                            <CheckDistanceSinceScoop threshold_name="stop_accumulation_distance"/>
                                            <StopPointAccumulation/>
                                        </Sequence>

                                        <!-- 远离铲装点后等待点云处理完成 -->
                                        <Sequence name="SEQ_SET_STATE_7_ON_RETREAT">
                                            <CheckDistanceSinceScoop threshold_name="retreat_check_distance"/>
                                            <SetArmBucketState code="8"/>
                                            <WaitForArmBucketCompletion timeout_s="300" message="Retreated from scoop, waiting for transit pose"/>
                                        </Sequence>
                                    </Parallel>

                                    <!-- 到达卸料仓后执行卸料 -->
                                    <Sequence name="SEQ_DUMP_ON_ARRIVAL">
                                        <SetArmBucketState name="SetABS_6" code="6"/>
                                        <WaitForArmBucketCompletion name="WaitABS_6" timeout_s="300" message="Arrived at hopper, executing dump"/>
                                    </Sequence>
                                </Sequence>

                                <!--
                                  ==============================================================
                                  SEQ_AFTER_CYCLE_DONE: 循环完成处理
                                  ==============================================================
                                  重置状态准备下一循环，并检查是否有待执行的避障
                                -->
                                <Sequence name="SEQ_AFTER_CYCLE_DONE">
                                    <SetWorkState value="8"/>
                                    <!-- 延迟一秒 -->
                                    <Sleep msec="1000"/>
                                    <SetWorkState value="1"/>
                                    <Script code="just_left_hopper:=true"/>

                                    <!-- 检查是否有 ctrlCmd=3 触发的待执行避障 -->
                                    <Fallback name="FALLBACK_CHECK_OBSTACLE_PENDING">
                                        <!-- 待执行避障：完成当前任务后去避障点 -->
                                        <Sequence name="SEQ_OBSTACLE_AFTER_TASK">
                                            <CheckObstaclePending/>
                                            <TriggerObstacleAvoidance/>
                                            <AlwaysFailure/>
                                        </Sequence>
                                        <!-- 无待执行避障，正常继续 -->
                                        <AlwaysSuccess/>
                                    </Fallback>
                                </Sequence>

                            </Sequence>
                        </Fallback>
                    </Sequence>
                </KeepRunningUntilFailure>

                <!--
                  ==============================================================
                  Idle: 空闲待机状态
                  ==============================================================
                  当主循环失败或无任务时执行
                  状态: 等待任务
                -->
                <Sequence>
                    <SetWorkState value="1"/>
                    <UpdateTaskProgress name="IdleStatus" phase="idle" progress="100.0" message="Idle, waiting for tasks"/>
                </Sequence>
            </Fallback>

        </ReactiveFallback>
    </BehaviorTree>

</root>
