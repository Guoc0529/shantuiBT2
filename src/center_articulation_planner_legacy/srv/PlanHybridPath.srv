# Request
geometry_msgs/PoseStamped start
geometry_msgs/PoseStamped goal
int8 task_type
---
# Response
bool success
string message
nav_msgs/Path path
int8[] direction_flags   # Same length as segment_starts/segment_ends; forward/backward/turning markers
int32[] segment_starts   # Optional segment start indices (inclusive)
int32[] segment_ends     # Optional segment end indices (inclusive, same length as segment_starts)
float64 planning_time_sec
