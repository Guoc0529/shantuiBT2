{
  // vehicle shape (detailed)
  "front_length": 0.5,
  "rear_length": 0.5,
  "width": 0.3,
  "front_to_hitch": 0.2,
  "rear_to_hitch": 0.2,
  "tool_length": 0.0,
  "safety_margin": 0.1,

  // legacy footprints for HybridAStar
  "legacy_length": 8.6,
  "legacy_width": 2.8,
  "legacy_rear_axle_dist": 2.1,
  "legacy_turning_clear_length": 6.1,
  "legacy_turning_clear_width_scale": 1.0,

  // discretization & kinematics
  "max_steering_angle_deg": 29.0,
  "steering_angle_discrete_num": 8,
  "wheel_base": 3.4,
  "state_grid_resolution": 1.0,
  "segment_length": 1.6,
  "segment_length_discrete_num": 8,
  "min_turning_radius": 7.2,
  "grid_size_phi": 72,

  // costs/penalties
  "steering_penalty": 3.0,
  "reversing_penalty": 1.0,
  "steering_change_penalty": 2.0,
  "w_ref": 0.0,

  // search behavior
  "shot_distance": 3.0,
  "use_dubins_or_rs": 1,

  // turning rectangle check
  "turning_check_enable": true,
  "turning_extend_length": 3.0,

  // map/ESDF settings
  "costmap_occ_threshold": 50,
  "costmap_unknown_is_obstacle": false,
  "esdf_vis_max_dist": 5.0,
  "esdf_pub_hz": 1.0,
  "esdf_use_costmap": true,
  "esdf_resolution_override": 0.0
}
